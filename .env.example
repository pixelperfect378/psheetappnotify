# Server
PORT=3000
NODE_ENV=development

# CORS — set to your Android debug host or production domain
ALLOWED_ORIGIN=*

# Google Sheets API
# Path to your Google service account JSON file (for Sheets API)
GOOGLE_SERVICE_ACCOUNT_KEY_PATH=./firebase-service-account.json
# OR inline JSON (for Railway/Render environment variables)
# GOOGLE_SERVICE_ACCOUNT_KEY_JSON={"type":"service_account",...}

# Firebase Admin SDK
# Same service account can be reused if it has both Sheets + FCM permissions
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Firebase project ID
FIREBASE_PROJECT_ID=your-firebase-project-id

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Secret for internal webhook calls (Apps Script → /notification)
APPS_SCRIPT_SECRET=change-me-to-a-strong-random-string
